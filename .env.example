# Ollama 服务地址（默认本地）
OLLAMA_BASE_URL=http://127.0.0.1:11434

# 默认对话/剧情生成模型（需先 ollama pull）
OLLAMA_MODEL=llama3

# 向量记忆使用的嵌入模型（可与对话模型相同或选用专用嵌入模型）
OLLAMA_EMBED_MODEL=nomic-embed-text

# LLM 读超时（秒，单次请求等待模型输出的上限）
OLLAMA_TIMEOUT=120

# 连接 Ollama 的超时（秒；服务未启动时可较快失败并走降级）
OLLAMA_CONNECT_TIMEOUT=8

# 是否启用简单响应缓存（相同提示词复用结果）
LLM_CACHE_ENABLED=true

# 用户输入最大长度（字符）
MAX_USER_INPUT_LENGTH=2000

# 可选：PostgreSQL 奪舍/快照池（未设置则存档页不显示云同步；需 pip install psycopg2-binary）
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/text_adventure

# 可选：默认用于「上傳快照」的 players.player_id（UUID），也可在界面每次填写
# POSSESSION_PLAYER_ID=00000000-0000-0000-0000-000000000000
