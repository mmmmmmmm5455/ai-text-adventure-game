# Ollama 服务地址（默认本地）
OLLAMA_BASE_URL=http://127.0.0.1:11434

# 默认对话/剧情生成模型（需先 ollama pull）
OLLAMA_MODEL=llama3

# 向量记忆使用的嵌入模型（可与对话模型相同或选用专用嵌入模型）
OLLAMA_EMBED_MODEL=nomic-embed-text

# LLM 超时（秒）
OLLAMA_TIMEOUT=120

# 是否启用简单响应缓存（相同提示词复用结果）
LLM_CACHE_ENABLED=true

# 用户输入最大长度（字符）
MAX_USER_INPUT_LENGTH=2000
